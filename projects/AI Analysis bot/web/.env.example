# 1% AI Lab — Phase 1 env vars
# Copy to .env (or .env.local) and fill in.

# Neon Postgres connection string. Region: ap-southeast-1 (Singapore).
DATABASE_URL=postgresql://neondb_owner:npg_cHiFICSP60Oh@ep-nameless-rain-aom9b85g.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Session cookie signing key. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SESSION_SECRET=replace-me-with-a-64-byte-random-string

# Admin email — the only account that can approve/reject /verify requests
# in Phase 2. Must match an email address registered via web sign-up.
ADMIN_EMAIL=you@example.com

# Phase 5: ngrok URL for the local Ollama tunnel. Leave blank in Phase 1.
OLLAMA_BASE_URL=

# Phase 5: Resend API key for password reset emails.
RESEND_API_KEY=
