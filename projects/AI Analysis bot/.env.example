# XOX Analysis Bot — Environment Variables

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Admin Telegram User ID (your account)
ADMIN_USER_ID=1701985687

# Ollama (local vision model)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=kimi-k2.6:cloud

# Optional: Binance API (for higher rate limits)
BINANCE_API_KEY=optional
BINANCE_SECRET_KEY=optional

# Database
DATABASE_PATH=users.db

# Server
API_HOST=0.0.0.0
API_PORT=8000
